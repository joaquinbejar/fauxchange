# fauxchange — example environment configuration.
#
# Copy to `.env` and adjust. NEVER commit a real `.env` (it may hold secrets).
# These env vars are the ENVIRONMENT layer of the layered config surface
# (defaults -> config file -> environment -> CLI flags; later layers win).
# Each value below is also settable in a TOML config file (--config <path>) and
# overridable by the matching CLI flag. See docs/06-deployment.md section 4.

# ----------------------------------------------------------------------------
# [server] REST/WS bind address. host:port. CLI: --http-addr
# Default: 0.0.0.0:8080
# ----------------------------------------------------------------------------
# FAUXCHANGE_HTTP_ADDR=0.0.0.0:8080

# ----------------------------------------------------------------------------
# [fix] FIX 4.4 bind address. host:port. CLI: --fix-addr
# Default: 0.0.0.0:9878
# ----------------------------------------------------------------------------
# FAUXCHANGE_FIX_ADDR=0.0.0.0:9878

# ----------------------------------------------------------------------------
# [persistence] PostgreSQL connection string. CLI: --database-url
# UNSET => fully in-memory (no database). SET => durable Postgres backend (#23).
# SECRET: never logged (redacted in the effective-config boot line).
# Range: a valid postgres:// URL.
# ----------------------------------------------------------------------------
# DATABASE_URL=postgres://fauxchange:fauxchange@localhost:5432/fauxchange

# ----------------------------------------------------------------------------
# [clock] Venue clock mode. CLI: --clock
# One of: realtime | accelerated | stepped   Default: realtime
# (Carried through in v0.2; the advanceable/stepped clock services land in #28.)
# ----------------------------------------------------------------------------
# FAUXCHANGE_CLOCK=realtime

# ----------------------------------------------------------------------------
# [determinism] One run-level seed. CLI: --seed
# Non-negative u64. Default: 0. Feeds the run lineage id namespace.
# ----------------------------------------------------------------------------
# FAUXCHANGE_SEED=0

# ----------------------------------------------------------------------------
# [auth] Operator secret gating token issuance (POST /api/v1/auth/token).
# UNSET => token issuance disabled. SECRET: never logged.
# Range: any non-empty string (an empty value is treated as unset).
# ----------------------------------------------------------------------------
# AUTH_BOOTSTRAP_SECRET=change-me-in-production

# ----------------------------------------------------------------------------
# [logging] Log output format. CLI: --log-format
# One of: json | pretty   Default: pretty
# (v0.2 validates + logs the choice; structured JSON emission lands with #06.)
# ----------------------------------------------------------------------------
# FAUXCHANGE_LOG_FORMAT=pretty

# ----------------------------------------------------------------------------
# tracing subscriber filter (standard RUST_LOG). Default: info
# ----------------------------------------------------------------------------
# RUST_LOG=info

# ----------------------------------------------------------------------------
# Underlyings to host (comma-separated). Default: BTC,ETH
# The declarative [instruments.*] seed manifest lands in #24; until then this
# env var seeds the hosted underlyings.
# ----------------------------------------------------------------------------
# FAUXCHANGE_UNDERLYINGS=BTC,ETH

# ----------------------------------------------------------------------------
# Optional Argon2 server-side pepper for FIX password hashing. SECRET: never
# logged, never stored with the hash. UNSET => no pepper.
# ----------------------------------------------------------------------------
# AUTH_PASSWORD_PEPPER=

# ----------------------------------------------------------------------------
# Admit the embedded, NON-SECRET dev JWT keypair for local use. 1/true enables.
# A published image refuses the dev keys unless this is set. Default: disabled.
# ----------------------------------------------------------------------------
# FAUXCHANGE_DEV=
